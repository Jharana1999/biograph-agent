# Copy to .env and fill values.

# LLM
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Managed Postgres (recommended for free deployment: Neon/Supabase free tier)
POSTGRES_DSN=postgresql+asyncpg://user:password@host:5432/dbname

# Managed Neo4j (recommended for free deployment: Neo4j Aura Free)
NEO4J_URI=bolt+s://your-neo4j-host.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# HTTP
HTTP_TIMEOUT_S=30

# Comma-separated allowed origins for browser calls to backend.
# Keep localhost for development.
CORS_ORIGINS=http://localhost:4200,https://your-frontend-domain.example
